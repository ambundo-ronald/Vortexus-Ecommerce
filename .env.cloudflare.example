POSTGRES_DB=vortexus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-local-password
APP_ENV_FILE=./.env.cloudflare.app
CADDYFILE_PATH=./deploy/Caddyfile.tunnel
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443

# Public hostnames configured in Cloudflare Tunnel public hostnames.
# Do not include https:// here; Caddy matches the Host header.
STOREFRONT_DOMAIN=vortexus.example.com
DASHBOARD_DOMAIN=admin.vortexus.example.com
API_DOMAIN=api.vortexus.example.com

# Frontend build-time API values. Rebuild frontend/dashboard after changing these.
VITE_API_BASE_URL=https://api.vortexus.example.com
VITE_API_PREFIX=/api/v1
NUXT_PUBLIC_API_BASE=https://api.vortexus.example.com/api/v1

# Paste the token from Cloudflare Zero Trust > Networks > Tunnels > your tunnel > Add a connector.
CLOUDFLARE_TUNNEL_TOKEN=

OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_INITIAL_ADMIN_PASSWORD=VortexusLocalAdmin123!
