DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=local-cloudflare-tunnel-change-me-to-a-long-random-secret
EMAIL_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_ALLOWED_HOSTS=api.vortexus.example.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://vortexus.example.com,https://admin.vortexus.example.com
CSRF_TRUSTED_ORIGINS=https://vortexus.example.com,https://admin.vortexus.example.com,https://api.vortexus.example.com
STOREFRONT_BASE_URL=https://vortexus.example.com

ENABLE_ASYNC_TASKS=True
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True

OSCAR_SHOP_NAME=Vortexus Industrial
MEDIA_ROOT=/app/media
DJANGO_SERVE_MEDIA_FILES=True
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=15728640
MAX_IMAGE_UPLOAD_BYTES=5242880
MAX_PRODUCT_IMAGE_BYTES=10485760
MAX_IMAGE_DIMENSION=1600
MAX_PRODUCT_IMAGE_DIMENSION=2400
NORMALIZED_IMAGE_FORMAT=WEBP
NORMALIZED_IMAGE_QUALITY=82
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp

IMAGE_EMBEDDING_BACKEND=hash
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
CLIP_DEVICE=cpu

DEFAULT_FROM_EMAIL=no-reply@vortexus.local
NOTIFICATION_REPLY_TO_EMAIL=
