REDIS_URL=redis://127.0.0.1:6379/0
OPENSEARCH_HOST=http://127.0.0.1:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OSCAR_SHOP_NAME=Vortexus Industrial
IMAGE_EMBEDDING_BACKEND=clip
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
