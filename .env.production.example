POSTGRES_DB=vortexus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
APP_ENV_FILE=./.env.production

STOREFRONT_DOMAIN=reesolmart.com
DASHBOARD_DOMAIN=reesolmart.cloud
API_DOMAIN=api.reesolmart.cloud

VITE_API_BASE_URL=https://api.reesolmart.cloud
VITE_API_PREFIX=/api/v1
VITE_STOREFRONT_ORIGIN=https://reesolmart.com
VITE_SEO_SITEMAP_URL=https://reesolmart.com/sitemap.xml
VITE_SEO_API_BASE_URL=https://api.reesolmart.cloud/api/v1
NUXT_PUBLIC_API_BASE=https://api.reesolmart.cloud/api/v1

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-this-django-secret-key
EMAIL_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_SAMESITE=None
DJANGO_CSRF_COOKIE_SAMESITE=None
ALLOW_INSECURE_PUBLIC_URLS=False
DJANGO_ALLOWED_HOSTS=api.reesolmart.cloud,localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=https://reesolmart.com,https://www.reesolmart.com,https://reesolmart.cloud
CSRF_TRUSTED_ORIGINS=https://reesolmart.com,https://www.reesolmart.com,https://reesolmart.cloud,https://api.reesolmart.cloud
STOREFRONT_BASE_URL=https://reesolmart.com
BACKEND_PUBLIC_BASE_URL=https://api.reesolmart.cloud

ENABLE_ASYNC_TASKS=True
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True

OSCAR_SHOP_NAME=Reesolmart
MEDIA_ROOT=/app/media
BACKUP_ROOT=/app/backups
BACKUP_STORAGE_BACKEND=local
BACKUP_LOCAL_KEEP=30
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=15728640
MAX_IMAGE_UPLOAD_BYTES=5242880
MAX_PRODUCT_IMAGE_BYTES=10485760
MAX_IMAGE_DIMENSION=1600
MAX_PRODUCT_IMAGE_DIMENSION=2400
NORMALIZED_IMAGE_FORMAT=WEBP
NORMALIZED_IMAGE_QUALITY=82
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp

IMAGE_EMBEDDING_BACKEND=clip
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
CLIP_DEVICE=cpu
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_INITIAL_ADMIN_PASSWORD=change-this-opensearch-admin-password
PRODUCT_MICROSERVICE_BASE_URL=http://product-microservice:3029
PRODUCT_MICROSERVICE_DATABASE_URL=mongodb://product-mongo:27017/vortexus_products
BACKEND_BIND=127.0.0.1
BACKEND_PORT=8000
STOREFRONT_BIND=127.0.0.1
STOREFRONT_PORT=5174
DASHBOARD_BIND=127.0.0.1
DASHBOARD_PORT=3000
PRODUCT_MICROSERVICE_BIND=127.0.0.1
PRODUCT_MICROSERVICE_PORT=3029

DEFAULT_FROM_EMAIL=no-reply@reesolmart.com
NOTIFICATION_REPLY_TO_EMAIL=
SALES_NOTIFICATION_RECIPIENTS=sales@reesolmart.com
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
