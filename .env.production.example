POSTGRES_DB=vortexus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
APP_ENV_FILE=./.env.production

STOREFRONT_DOMAIN=vortexus.example.com
DASHBOARD_DOMAIN=admin.vortexus.example.com
API_DOMAIN=api.vortexus.example.com

VITE_API_BASE_URL=https://api.vortexus.example.com
VITE_API_PREFIX=/api/v1
NUXT_PUBLIC_API_BASE=https://api.vortexus.example.com/api/v1

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-this-django-secret-key
EMAIL_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_ALLOWED_HOSTS=api.vortexus.example.com
CORS_ALLOWED_ORIGINS=https://vortexus.example.com,https://admin.vortexus.example.com
CSRF_TRUSTED_ORIGINS=https://vortexus.example.com,https://admin.vortexus.example.com,https://api.vortexus.example.com
STOREFRONT_BASE_URL=https://vortexus.example.com

ENABLE_ASYNC_TASKS=True
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True

OSCAR_SHOP_NAME=Vortexus Industrial
MEDIA_ROOT=/app/media
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=15728640
MAX_IMAGE_UPLOAD_BYTES=5242880
MAX_PRODUCT_IMAGE_BYTES=10485760
MAX_IMAGE_DIMENSION=1600
MAX_PRODUCT_IMAGE_DIMENSION=2400
NORMALIZED_IMAGE_FORMAT=WEBP
NORMALIZED_IMAGE_QUALITY=82
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp

IMAGE_EMBEDDING_BACKEND=clip
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
CLIP_DEVICE=cpu
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_INITIAL_ADMIN_PASSWORD=change-this-opensearch-admin-password

DEFAULT_FROM_EMAIL=no-reply@vortexus.example.com
NOTIFICATION_REPLY_TO_EMAIL=
SALES_NOTIFICATION_RECIPIENTS=sales@vortexus.example.com

MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://api.vortexus.example.com/api/v1/payments/mpesa/callback/
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_TIMEOUT_SECONDS=30

AIRTEL_MONEY_SANDBOX_ENABLED=True
AIRTEL_MONEY_PROVIDER_NAME=sandbox_airtel_money
CARD_SANDBOX_ENABLED=True
CARD_PROVIDER_NAME=sandbox_card

ERP_SYNC_TIMEOUT_SECONDS=30
ERPNEXT_DEFAULT_PRICE_LIST=Standard Selling
OSCAR_DELETE_IMAGE_FILES=False
