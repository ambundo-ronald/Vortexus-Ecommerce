# Leave empty in local development to use Vite's same-origin proxy.
# Set this to the public API origin for separate-domain deployments.
VITE_API_BASE_URL=
VITE_API_PREFIX=/api/v1
VITE_STOREFRONT_ORIGIN=http://127.0.0.1:5174
VITE_SEO_SITEMAP_URL=
VITE_SEO_API_BASE_URL=http://127.0.0.1:8000/api/v1
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=5174
