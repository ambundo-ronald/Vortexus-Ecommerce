POSTGRES_DB=vortexus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
APP_ENV_FILE=./.env.docker.local

STOREFRONT_DOMAIN=http://localhost
DASHBOARD_DOMAIN=http://dashboard.localhost
API_DOMAIN=http://api.localhost

VITE_API_BASE_URL=http://192.168.1.218:8000
VITE_API_PREFIX=/api/v1
VITE_STOREFRONT_ORIGIN=http://localhost
VITE_SEO_SITEMAP_URL=
VITE_SEO_API_BASE_URL=
NUXT_PUBLIC_API_BASE=http://192.168.1.218:8000/api/v1

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=local-docker-change-me-to-a-long-random-secret-before-sharing
EMAIL_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
ALLOW_INSECURE_PUBLIC_URLS=True
DJANGO_ALLOWED_HOSTS=api.localhost,localhost,127.0.0.1,192.168.1.218
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5174,http://localhost:3000,http://dashboard.localhost,http://192.168.1.218:5174,http://192.168.1.218:3000
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:5174,http://localhost:3000,http://dashboard.localhost,http://api.localhost,http://192.168.1.218:5174,http://192.168.1.218:3000,http://192.168.1.218:8000
STOREFRONT_BASE_URL=http://localhost
BACKEND_PUBLIC_BASE_URL=http://192.168.1.218:8000

ENABLE_ASYNC_TASKS=True
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True

OSCAR_SHOP_NAME=Vortexus Industrial
MEDIA_ROOT=/app/media
BACKUP_ROOT=/app/backups
BACKUP_STORAGE_BACKEND=local
BACKUP_LOCAL_KEEP=30
DJANGO_SERVE_MEDIA_FILES=True
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=15728640
MAX_IMAGE_UPLOAD_BYTES=5242880
MAX_PRODUCT_IMAGE_BYTES=10485760
MAX_IMAGE_DIMENSION=1600
MAX_PRODUCT_IMAGE_DIMENSION=2400
NORMALIZED_IMAGE_FORMAT=WEBP
NORMALIZED_IMAGE_QUALITY=82
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp

IMAGE_EMBEDDING_BACKEND=hash
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
CLIP_DEVICE=cpu
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_INITIAL_ADMIN_PASSWORD=VortexusLocalAdmin123!
PRODUCT_MICROSERVICE_BASE_URL=http://product-microservice:3029
PRODUCT_MICROSERVICE_DATABASE_URL=mongodb://product-mongo:27017/vortexus_products
PRODUCT_MICROSERVICE_BIND=127.0.0.1
PRODUCT_MICROSERVICE_PORT=3029

DEFAULT_FROM_EMAIL=no-reply@vortexus.local
NOTIFICATION_REPLY_TO_EMAIL=
SALES_NOTIFICATION_RECIPIENTS=sales@vortexus.local

MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://192.168.1.218:8000/api/v1/payments/mpesa/callback/
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_TIMEOUT_SECONDS=30

AIRTEL_MONEY_SANDBOX_ENABLED=True
AIRTEL_MONEY_PROVIDER_NAME=sandbox_airtel_money
CARD_SANDBOX_ENABLED=True
CARD_PROVIDER_NAME=sandbox_card

ERP_SYNC_TIMEOUT_SECONDS=30
ERP_SYNC_PAGE_LENGTH=1000
ERPNEXT_DEFAULT_PRICE_LIST=Standard Selling
OSCAR_DELETE_IMAGE_FILES=False
